# J1 NOC Nexus — Environment Configuration
# Copy this file to .env and fill in your values.
# All fields with "change_me" MUST be changed before production use.

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=change_me_your_telegram_bot_token
ADMIN_CHAT_IDS=change_me_comma_separated_chat_ids

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_PORT=5000
AGENT_PORT=8080
SECRET_KEY=change_me_generate_random_secret

# ── SNMP Discovery ─────────────────────────────────────────
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# ── Network ───────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=60
PING_TIMEOUT_SECONDS=2

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/app/logs/nexus.log
